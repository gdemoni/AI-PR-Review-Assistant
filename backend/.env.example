# ============================================================
# LLM 供应商配置（5 家主流模型，设 LLM_PROVIDER 切换）
# ============================================================
# 可选: deepseek | qwen | zhipu | moonshot | openai
LLM_PROVIDER=deepseek

# 模型名称（可选，不填则使用各供应商默认模型，注释中列出了可选模型）
# LLM_MODEL=

# ── DeepSeek（deepseek-chat / deepseek-reasoner）──
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── 阿里通义千问（qwen-turbo / qwen-plus / qwen-max）──
# QWEN_API_KEY=your_qwen_api_key_here

# ── 智谱 GLM（glm-4-flash / glm-4-plus / glm-4-air）──
# ZHIPU_API_KEY=your_zhipu_api_key_here

# ── 月之暗面 Kimi（moonshot-v1-8k / 32k / 128k）──
# MOONSHOT_API_KEY=your_moonshot_api_key_here

# ── OpenAI / ChatGPT（GPT-4o）──
# OPENAI_API_KEY=your_openai_api_key_here

# ── GitHub Token（访问私有仓库必需，公开仓库可选突破速率限制）──
# 创建地址: https://github.com/settings/tokens
# 权限: 勾选 repo（私有仓库） 或 public_repo（仅公开仓库）
GITHUB_TOKEN=your_github_token_here

# Server Port
PORT=8000
